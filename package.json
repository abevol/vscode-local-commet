{
  "name": "vscode-local-comment",
  "displayName": "Local Comment(本地注释)",
  "description": "Add local comments for your code, support user-defined tag jumps，support markdown notes, latex,mermaid flowcharts. The modification will not affect the original file. (支持用户标签跳转，markdown笔记，mermaid流程图latex公式。修改不会影响原文件)",
  "version": "1.3.3",
  "publisher": "sangliang",
  "author": {
    "name": "SangLiang",
    "email": "378305868@qq.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SangLiang/vscode-local-commet.git"
  },
  "homepage": "https://github.com/SangLiang/vscode-local-commet",
  "bugs": {
    "url": "https://github.com/SangLiang/vscode-local-commet/issues"
  },
  "keywords": [
    "local comment",
    "annotation",
    "tag",
    "note",
    "mermaid",
    "latex",
    "flowchart",
    "documentation",
    "code-comment",
    "productivity",
    "bookmark",
    "teamwork",
    "note book",
    "markdown",
    "AI recorder"
  ],
  "categories": [
    "Other",
    "Education"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#2B5797",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localComment.addComment",
        "title": "%addComment%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.addMarkdownComment",
        "title": "%addMarkdownComment%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.convertSelectionToComment",
        "title": "%convertSelectionToComment%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.editCommentFromHover",
        "title": "%editCommentFromHover%",
        "category": "Local Comment",
        "when": false
      },
      {
        "command": "localComment.removeComment",
        "title": "%removeComment%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.toggleComments",
        "title": "%toggleComments%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.goToComment",
        "title": "%goToComment%",
        "category": "Local Comment",
        "when": false
      },
      {
        "command": "localComment.goToTagDeclaration",
        "title": "%goToTagDeclaration%",
        "category": "Local Comment",
        "when": false
      },
      {
        "command": "localComment.refreshTree",
        "title": "%refreshTree%",
        "icon": "$(refresh)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.deleteCommentFromTree",
        "title": "%deleteCommentFromTree%",
        "icon": "$(trash)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.clearFileComments",
        "title": "%clearFileComments%",
        "icon": "$(clear-all)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.clearAllSharedComments",
        "title": "%clearAllSharedComments%",
        "icon": "$(clear-all)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.clearFileSharedComments",
        "title": "%clearFileSharedComments%",
        "icon": "$(clear-all)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.editCommentFromTree",
        "title": "%editCommentFromTree%",
        "icon": "$(edit)",
        "category": "Local Comment",
        "when": false
      },
      {
        "command": "localComment.showStorageLocation",
        "title": "%showStorageLocation%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.switchCommentsConfig",
        "title": "%switchCommentsConfig%",
        "category": "Local Comment",
        "icon": "$(file-submodule)"
      },
      {
        "command": "localComment.switchBookmarksConfig",
        "title": "%switchBookmarksConfig%",
        "category": "Local Comment",
        "icon": "$(file-submodule)"
      },
      {
        "command": "localComment.migrateOldData",
        "title": "%migrateOldData%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.showStorageStats",
        "title": "%showStorageStats%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.manageProjects",
        "title": "%manageProjects%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.exportComments",
        "title": "%exportComments%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.importComments",
        "title": "%importComments%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.fuzzyMatchComment",
        "title": "%fuzzyMatchComment%",
        "icon": "$(search-fuzzy)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.updateCommentLine",
        "title": "%updateCommentLine%",
        "icon": "$(go-to-file)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.goToFile",
        "title": "%goToFile%",
        "icon": "$(arrow-right)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.addBookmark",
        "title": "%addBookmark%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.toggleBookmark",
        "title": "%toggleBookmark%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.goToBookmark",
        "title": "%goToBookmark%",
        "category": "Local Comment",
        "when": false
      },
      {
        "command": "localComment.deleteBookmarkFromTree",
        "title": "%deleteBookmarkFromTree%",
        "icon": "$(trash)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.clearFileBookmarks",
        "title": "%clearFileBookmarks%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.clearAllBookmarks",
        "title": "%clearAllBookmarks%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.goToNextBookmark",
        "title": "%goToNextBookmark%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.goToPreviousBookmark",
        "title": "%goToPreviousBookmark%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.showCurrentFileBookmarks",
        "title": "%showCurrentFileBookmarks%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.logout",
        "title": "%logout%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.showUserInfo",
        "title": "%showUserInfo%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.refreshSharedComments",
        "title": "%refreshSharedComments%",
        "icon": "$(refresh)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.showShareComment",
        "title": "%showShareComment%",
        "icon": "$(arrow-right)",
        "category": "Local Comment"
      },
      {
        "command": "localComment.previewSharedComment",
        "title": "%previewSharedComment%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.showCurrentFileTags",
        "title": "%showCurrentFileTags%",
        "category": "Local Comment"
      },
      {
        "command": "localComment.showAllFilesTags",
        "title": "%showAllFilesTags%",
        "category": "Local Comment"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "localComments",
          "name": "%treeViewTitle%",
          "when": "true"
        },
        {
          "id": "sharedComments",
          "name": "%sharedCommentsTreeViewTitle%",
          "when": "localComment.hasSharedComments && localComment.isLoggedIn"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "localComment.editCommentFromHover",
          "when": "false"
        },
        {
          "command": "localComment.goToComment",
          "when": "false"
        },
        {
          "command": "localComment.goToTagDeclaration",
          "when": "false"
        },
        {
          "command": "localComment.editCommentFromTree",
          "when": "false"
        },
        {
          "command": "localComment.clearFileComments",
          "when": "false"
        },
        {
          "command": "localComment.fuzzyMatchComment",
          "when": "false"
        },
        {
          "command": "localComment.updateCommentLine",
          "when": "false"
        },
        {
          "command": "localComment.goToFile",
          "when": "false"
        },
        {
          "command": "localComment.goToBookmark",
          "when": "false"
        },
        {
          "command": "localComment.switchCommentsConfig",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "localComment.switchBookmarksConfig",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "localComment.migrateOldData",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "editor/context": [
        {
          "command": "localComment.addComment",
          "group": "localComment",
          "when": "editorTextFocus"
        },
        {
          "command": "localComment.convertSelectionToComment",
          "group": "localComment",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "localComment.removeComment",
          "group": "localComment",
          "when": "editorTextFocus"
        },
        {
          "command": "localComment.toggleBookmark",
          "group": "localComment",
          "when": "editorTextFocus"
        },
        {
          "command": "localComment.showCurrentFileTags",
          "group": "localComment",
          "when": "editorTextFocus"
        }
      ],
      "view/title": [
        {
          "command": "localComment.refreshTree",
          "when": "view == localComments",
          "group": "navigation"
        },
        {
          "command": "localComment.refreshSharedComments",
          "when": "view == sharedComments",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "localComment.editCommentFromTree",
          "when": "view == localComments && viewItem == comment",
          "group": "inline"
        },
        {
          "command": "localComment.deleteCommentFromTree",
          "when": "view == localComments && viewItem == comment",
          "group": "inline"
        },
        {
          "command": "localComment.editCommentFromTree",
          "when": "view == localComments && viewItem == hidden-comment",
          "group": "inline"
        },
        {
          "command": "localComment.deleteCommentFromTree",
          "when": "view == localComments && viewItem == hidden-comment",
          "group": "inline"
        },
        {
          "command": "localComment.clearFileComments",
          "when": "view == localComments && viewItem == file",
          "group": "context"
        },
        {
          "command": "localComment.fuzzyMatchComment",
          "when": "view == localComments && viewItem == hidden-comment",
          "group": "context"
        },
        {
          "command": "localComment.updateCommentLine",
          "when": "view == localComments && viewItem == comment",
          "group": "context"
        },
        {
          "command": "localComment.updateCommentLine",
          "when": "view == localComments && viewItem == hidden-comment",
          "group": "context"
        },
        {
          "command": "localComment.goToFile",
          "when": "view == localComments && viewItem == file",
          "group": "inline"
        },
        {
          "command": "localComment.deleteBookmarkFromTree",
          "when": "view == localComments && viewItem == bookmark",
          "group": "inline"
        },
        {
          "command": "localComment.clearFileBookmarks",
          "when": "view == localComments && viewItem == file",
          "group": "context"
        },
        {
          "command": "localComment.showShareComment",
          "when": "view == sharedComments && (viewItem == shared-comment || viewItem == shared-comment-unmatched)",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "localComment.addComment",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      },
      {
        "command": "localComment.addMarkdownComment",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorTextFocus"
      },
      {
        "command": "localComment.removeComment",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "localComment.addMarkdownComment",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      },
      {
        "command": "localComment.convertSelectionToComment",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "localComment.toggleBookmark",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "localComment.goToNextBookmark",
        "key": "ctrl+alt+j",
        "mac": "cmd+alt+j",
        "when": "editorTextFocus"
      },
      {
        "command": "localComment.goToPreviousBookmark",
        "key": "ctrl+alt+shift+j",
        "mac": "cmd+alt+shift+j",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Local Comment",
      "properties": {
        "local-comment.server.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "The base URL of the Local Comment server (e.g. http://127.0.0.1:8000)."
        },
        "local-comment.mermaid.theme": {
          "type": "string",
          "default": "hand-drawn",
          "description": "%mermaidThemeDescription%",
          "enum": [
            "default",
            "hand-drawn"
          ],
          "enumDescriptions": [
            "%mermaidThemeDefault%",
            "%mermaidThemeHandDrawn%"
          ]
        },
        "local-comment.codeHighlight.theme": {
          "type": "string",
          "default": "github-dark",
          "description": "代码高亮主题。可选主题：github-dark（GitHub 暗色）、github（GitHub 亮色）、vs2015（Visual Studio 2015）、monokai（Monokai）、vs（Visual Studio）等",
          "enum": [
            "github-dark",
            "github",
            "vs2015",
            "vs",
            "monokai",
            "atom-one-dark",
            "atom-one-light"
          ],
          "enumDescriptions": [
            "GitHub 暗色主题（推荐用于暗色 VS Code 主题）",
            "GitHub 亮色主题（推荐用于亮色 VS Code 主题）",
            "Visual Studio 2015 主题",
            "Visual Studio 主题",
            "Monokai 主题",
            "Atom One Dark 主题",
            "Atom One Light 主题"
          ]
        },
        "local-comment.markdownPreview.fontSize": {
          "type": "number",
          "default": 0,
          "description": "Markdown 预览区域的字体大小（像素）。设置为 0 时使用编辑器字体大小，设置为其他值时使用自定义大小。",
          "minimum": 0,
          "maximum": 100
        },
        "local-comment.storage.commentsConfig": {
          "type": "string",
          "default": "comments.json",
          "description": "当前使用的注释配置文件名（位于 .vscode/local-comment/comments/ 目录下）"
        },
        "local-comment.storage.bookmarksConfig": {
          "type": "string",
          "default": "bookmarks.json",
          "description": "当前使用的书签配置文件名（位于 .vscode/local-comment/bookmarks/ 目录下）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run copy-lib && npm run compile",
    "copy-lib": "node scripts/copy-lib-files.js",
    "compile": "npm run copy-lib && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run build:prod",
    "build:dev": "cross-env LOG_LEVEL=info NODE_ENV=development node scripts/set-log-level.js && node scripts/package-dev.js",
    "build:prod": "cross-env LOG_LEVEL=error NODE_ENV=production node scripts/set-log-level.js && npx @vscode/vsce package",
    "ls": "npx @vscode/vsce ls --tree"
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "cross-env": "^7.0.3",
    "katex": "^0.16.9",
    "marked": "^4.3.0",
    "mermaid": "^10.6.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.11.0"
  }
}
